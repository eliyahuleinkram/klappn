# Klappn environment. Copy to `.env` (local dev) or set as wrangler secrets
# (deploy — see README). Never commit real values.
#
# MINIMUM for local dev: DATABASE_URL + BETTER_AUTH_SECRET. Everything else
# unlocks a feature and is optional.

# --- Database ---------------------------------------------------------------
# Local dev: your local Postgres. Deployed: the app reads the Hyperdrive
# binding from wrangler.jsonc instead (no DATABASE_URL secret needed).
DATABASE_URL=postgres://user:password@localhost:5432/klappn
# HYPERDRIVE_CONNECTION_STRING=          # alternative direct override

# --- Auth (Better Auth, email OTP sign-in) ----------------------------------
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001

# --- Email (Cloudflare Email Service) ---------------------------------------
# Delivers the OTP sign-in codes. Unset locally → the code prints to the dev
# server console instead. EMAIL_FROM must be on a Cloudflare-verified domain.
# EMAIL_FROM=noreply@example.com
# CLOUDFLARE_EMAIL_API_TOKEN=            # falls back to CLOUDFLARE_API_TOKEN

# --- AI generation (server-side only) ---------------------------------------
# Default routing is Claude (Fable 5) — bring your own key; generation runs
# at your cost on your account. Model routing lives in lib/llm.ts /
# lib/models.ts. All other providers below are optional A/B toggles.
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=                          # optional override of the default
# MOONSHOT_API_KEY=                      # Kimi toggle (songs.model = "kimi")
# MOONSHOT_MODEL=
# MOONSHOT_BASE_URL=
# OPENROUTER_API_KEY=                    # OpenRouter slugs via songs.model
# TOGETHER_API_KEY=                      # also: ASR for the voice studio
# GEMINI_API_KEY=  BASETEN_API_KEY=  XAI_API_KEY=   # further toggles

# Testing: 1 mocks all model calls (no API cost) with valid playable Strudel.
KLAPPN_MOCK_LLM=0

# --- Background Workflows (Cloudflare) --------------------------------------
# Set → durable Workflows via the REST API. Unset (local dev) → generation
# runs in-process, no Cloudflare needed.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=                  # Workflows:Edit + Email Sending
GENERATION_WORKFLOW_NAME=klappn-generation
EDIT_WORKFLOW_NAME=klappn-edit

# --- Stripe (optional — token top-ups + event tickets) ----------------------
# Without these, billing UI still renders; purchases return a config error.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy subscription price ids (retired tiers; kept for existing subs):
# STRIPE_PRICE_CREATOR=  STRIPE_PRICE_STUDIO=  STRIPE_PRICE_LABEL=

# --- Live streaming (optional — Cloudflare Realtime SFU) --------------------
# REALTIME_APP_ID=
# REALTIME_APP_TOKEN=

# --- Render service (optional — mobile-twin cost measuring, Fly.io) ---------
# RENDER_ORIGIN=
# KLAPPN_RENDER_TOKEN=                   # shared secret with the render host
# KLAPPN_LLM_TOKEN=                      # shared secret for the LLM proxy
