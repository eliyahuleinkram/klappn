{
  "name": "klappn",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Open-source AI music studio — describe a sound, get editable, playable loops.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eliyahuleinkram/klappn.git"
  },
  "homepage": "https://klappn.com",
  "type": "module",
  "engines": {
    "node": ">=22.15"
  },
  "scripts": {
    "dev": "vinext dev --port 3001",
    "dev:next": "next dev",
    "build": "vinext build",
    "start": "vinext start",
    "deploy": "node scripts/stamp-engine.mjs && vinext build && npx wrangler deploy",
    "lint": "eslint",
    "test": "tsx --test lib/*.test.ts",
    "auth:generate": "better-auth generate --config lib/auth.ts -y",
    "auth:migrate": "better-auth migrate --config lib/auth.ts -y",
    "db:schema": "psql \"${DATABASE_URL:?export DATABASE_URL first — npm scripts do not read .env}\" -f lib/schema.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@strudel/hydra": "^1.2.6",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/web": "^1.3.0",
    "acorn": "^8.17.0",
    "better-auth": "^1.6.23",
    "hydra-synth": "^1.4.0",
    "kysely": "^0.29.3",
    "kysely-postgres-js": "^3.0.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.43.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^6",
    "vinext": "1.0.0-beta.0",
    "vite": "^8.1.3"
  }
}
